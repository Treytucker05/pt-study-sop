-export const CATEGORY_LABELS: Record<MethodCategory, string> = {
-  // Control Plane
-  PRIME: "PRIME",
-  CALIBRATE: "CALIBRATE",
-  ENCODE: "ENCODE",
-  REFERENCE: "REFERENCE",
-  RETRIEVE: "RETRIEVE",
-  OVERLEARN: "OVERLEARN",
-  // Legacy
-  prepare: "Prepare",
-  encode: "Encode",
-  interrogate: "Interrogate",
-  retrieve: "Retrieve",
-  refine: "Refine",
-  overlearn: "Overlearn",
-};
