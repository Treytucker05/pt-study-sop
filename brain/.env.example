# PT Study Brain environment template
#
# Live/operator runs may need some or all of these values.
# Hermetic harness runs must not depend on secrets in this file.

# Tutor embeddings
GEMINI_API_KEY=
GEMINI_API_KEY_BUSINESS=
GOOGLE_API_KEY=
OPENAI_API_KEY=
TUTOR_RAG_EMBEDDING_PROVIDER=gemini
TUTOR_RAG_GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Obsidian integration
OBSIDIAN_API_KEY=
OBSIDIAN_API_URL=http://127.0.0.1:27123
# Optional filesystem vault path for direct Obsidian read/write helpers.
# Windows example: C:\Users\treyt\Desktop\Treys School
# macOS example: /Users/fst/Desktop/Treys School/Treys School
OBSIDIAN_VAULT_FS_PATH=
PT_OBSIDIAN_VAULT_PATH=
OBSIDIAN_VAULT_NAME=Treys School

# Optional Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional harness/runtime overrides
# Study materials root.
# Windows example: C:\Users\treyt\OneDrive\Desktop\PT School
# macOS example: /Users/fst/Desktop/PT School
# PT_STUDY_RAG_DIR=
# PT_BRAIN_DATA_DIR=
# PT_BRAIN_SESSION_LOGS_DIR=
# PT_BRAIN_OUTPUT_DIR=
# PT_BRAIN_DB_PATH=
# PT_BRAIN_API_CONFIG_PATH=
# PT_BRAIN_HOST=127.0.0.1
# Windows default: 5000. macOS launcher default: 5127.
# PT_BRAIN_PORT=5000
